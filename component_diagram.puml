@startuml MNSCK_Component_Diagram
!theme plain
skinparam componentStyle rectangle
skinparam backgroundColor #FEFEFE
skinparam component {
    BackgroundColor<<UI>> #E1F5FE
    BackgroundColor<<Controller>> #FFF3E0
    BackgroundColor<<Service>> #F3E5F5
    BackgroundColor<<Repository>> #E8F5E9
    BackgroundColor<<Entity>> #FCE4EC
    BackgroundColor<<Pattern>> #FFF9C4
    BackgroundColor<<Infrastructure>> #EEEEEE
    BorderColor #333333
}

' ============================================
' CONTROL LAYER - Controllers
' ============================================
package "🎮 CONTROL LAYER" {
    component [IndexController] <<Controller>>
    component [TourController] <<Controller>>
    component [BookingController] <<Controller>>
    component [CustomerController] <<Controller>>
    component [GuideController] <<Controller>>
}

' ============================================
' SERVICE LAYER - Business Logic
' ============================================
package "⚙️ SERVICE LAYER" {
    component [PricingStrategyService] <<Service>>
    component [TourStatisticsService] <<Service>>
    component [BookingStatusChangedEvent] <<Pattern>>
    component [EmailNotificationListener] <<Pattern>>
}

' ============================================
' STRATEGY PATTERN - Pricing
' ============================================
package "💰 PRICING STRATEGY PATTERN" {
    component [DiscountStrategy] <<Pattern>>
    component [NoDiscountStrategy] <<Pattern>>
    component [VipCustomerStrategy] <<Pattern>>
    component [LastMinuteStrategy] <<Pattern>>
    component [DiscountStrategyFactory] <<Pattern>>
    component [PriceCalculator] <<Pattern>>

    DiscountStrategy --> NoDiscountStrategy
    DiscountStrategy --> VipCustomerStrategy
    DiscountStrategy --> LastMinuteStrategy
    DiscountStrategyFactory --> DiscountStrategy
    PriceCalculator --> DiscountStrategy
}

' ============================================
' STATE PATTERN - Booking States
' ============================================
package "📋 STATE PATTERN (Booking States)" {
    component [BookingState] <<Pattern>>
    component [WaitingForPaymentState] <<Pattern>>
    component [PartiallyPaidState] <<Pattern>>
    component [PaidState] <<Pattern>>
    component [CancelledState] <<Pattern>>

    BookingState --> WaitingForPaymentState
    BookingState --> PartiallyPaidState
    BookingState --> PaidState
    BookingState --> CancelledState
}

' ============================================
' REPOSITORY LAYER - Data Access
' ============================================
package "💾 REPOSITORY LAYER (Spring Data JPA)" {
    component [TourRepository] <<Repository>>
    component [BookingRepository] <<Repository>>
    component [CustomerRepository] <<Repository>>
    component [GuideRepository] <<Repository>>
    component [PaymentRepository] <<Repository>>
    component [DestinationRepository] <<Repository>>
    component [TransportRepository] <<Repository>>
    component [LanguageRepository] <<Repository>>
}

' ============================================
' ENTITY LAYER - Domain Objects
' ============================================
package "🏛️ ENTITY LAYER (Domain Model)" {
    component [Tour] <<Entity>>
    component [Booking] <<Entity>>
    component [Payment] <<Entity>>
    component [Customer] <<Entity>>
    component [Guide] <<Entity>>
    component [Destination] <<Entity>>
    component [Transport] <<Entity>>
    component [Language] <<Entity>>
    component [AppUser] <<Entity>>

    Booking --> Tour
    Booking --> Customer
    Booking --> Payment
    Tour --> Guide
    Tour --> Destination
    Tour --> Transport
    Guide --> Language
}

' ============================================
' INFRASTRUCTURE - Database
' ============================================
package "🔧 INFRASTRUCTURE" {
    component [H2 Database] <<Infrastructure>>
    component [Spring Framework IoC] <<Infrastructure>>
    component [Tomcat Servlet Container] <<Infrastructure>>
    component [Thymeleaf Template Engine] <<Infrastructure>>
    component [HTMX] <<Infrastructure>>
    component [Hibernate ORM] <<Infrastructure>>
}

' ============================================
' DEPENDENCIES & RELATIONSHIPS
' ============================================

' UI dependencies on Controllers
[tours-list.html] --> [TourController]
[bookings-list.html] --> [BookingController]
[customers-list.html] --> [CustomerController]
[guides-list.html] --> [GuideController]
[index.html] --> [IndexController]
[layout.html] -.-> [tours-list.html]
[layout.html] -.-> [bookings-list.html]
[layout.html] -.-> [customers-list.html]
[layout.html] -.-> [guides-list.html]

' Controllers depend on Services
[TourController] --> [TourStatisticsService]
[BookingController] --> [PricingStrategyService]
[BookingController] --> [BookingStatusChangedEvent]

' Controllers depend on Repositories
[TourController] --> [TourRepository]
[BookingController] --> [BookingRepository]
[CustomerController] --> [CustomerRepository]
[GuideController] --> [GuideRepository]
[TourController] --> [DestinationRepository]
[TourController] --> [TransportRepository]

' Services depend on Repositories & Patterns
[PricingStrategyService] --> [DiscountStrategyFactory]
[PricingStrategyService] --> [PriceCalculator]
[TourStatisticsService] --> [TourRepository]
[TourStatisticsService] --> [BookingRepository]

' Repositories depend on Entities
[TourRepository] --> [Tour]
[BookingRepository] --> [Booking]
[CustomerRepository] --> [Customer]
[GuideRepository] --> [Guide]
[PaymentRepository] --> [Payment]
[DestinationRepository] --> [Destination]
[TransportRepository] --> [Transport]
[LanguageRepository] --> [Language]

' Entities depend on State Pattern
[Booking] --> [BookingState]

' Services depends on Event/Listener
[EmailNotificationListener] --> [BookingStatusChangedEvent]

' Event Publishing
[BookingController] -.-> [EmailNotificationListener]

' Repositories depend on Hibernate
[TourRepository] -.-> [Hibernate ORM]
[BookingRepository] -.-> [Hibernate ORM]
[CustomerRepository] -.-> [Hibernate ORM]
[GuideRepository] -.-> [Hibernate ORM]

' Hibernate depends on Database
[Hibernate ORM] --> [H2 Database]

' Spring manages everything
[Spring Framework IoC] -.-> [TourController]
[Spring Framework IoC] -.-> [BookingController]
[Spring Framework IoC] -.-> [PricingStrategyService]
[Spring Framework IoC] -.-> [TourStatisticsService]
[Spring Framework IoC] -.-> [DiscountStrategyFactory]

' UI served by Tomcat
[Tomcat Servlet Container] -.-> [index.html]
[Tomcat Servlet Container] -.-> [tours-list.html]
[Tomcat Servlet Container] -.-> [bookings-list.html]

' Thymeleaf renders templates
[Thymeleaf Template Engine] -.-> [index.html]
[Thymeleaf Template Engine] -.-> [tours-list.html]
[Thymeleaf Template Engine] -.-> [bookings-list.html]

' HTMX provides dynamic updates
[HTMX] -.-> [TourController]
[HTMX] -.-> [BookingController]

@enduml

